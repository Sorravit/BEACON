# AI Assistant Configuration - IBM ICA
# Copy this file to .env and fill in your actual credentials
# DO NOT commit .env to version control!

# =============================================================================
# OpenAI-compatible Endpoint (ICA)
# =============================================================================
# OPENAI_API_KEY  : Auth token / API key for the endpoint.
OPENAI_API_KEY=your_ibm_ica_api_key_here

# OPENAI_BASE_URL : Full base URL of the OpenAI-compatible API.
OPENAI_BASE_URL=https://sg.ica.ibm.com/ica/apis/v3

# =============================================================================
# Dynamic Model Listing
# =============================================================================
# DYNAMIC_MODEL_LISTING_ENABLED
#   true  -> On startup (and on POST /models/reload) BEACON will call the ICA
#            endpoint GET /v1/models (OpenAI-compatible) to fetch the live
#            model catalogue and MERGE it with models.yaml entries.
#            The statically defined models in models.yaml always take priority
#            (richer meta labels, descriptions, tags, context sizes).
#            Models returned by the API that are NOT in models.yaml are added
#            automatically with a generated label.
#   false -> Classic behaviour: only models declared in models.yaml are shown.
DYNAMIC_MODEL_LISTING_ENABLED=true

# DYNAMIC_MODEL_LISTING_TIMEOUT_SECS
#   How long (seconds) to wait for the /v1/models response before falling back
#   to the static models.yaml list. Default: 10.
DYNAMIC_MODEL_LISTING_TIMEOUT_SECS=10

# LLM timeout knobs
#   LLM_STREAM_IDLE_TIMEOUT — max seconds of silence between streaming chunks
#     before the call is considered stalled. 0 = disabled (no limit). Default: 0.
# LLM_STREAM_IDLE_TIMEOUT=0
#
#   LLM_REQUEST_TIMEOUT — total wall-clock cap for non-streaming LLM calls.
#     0 = disabled (no limit). Default: 0.
# LLM_REQUEST_TIMEOUT=0

# DYNAMIC_MODEL_LISTING_PREFIX_FILTER
#   Optional comma-separated list of id-prefix strings. When set, only
#   dynamically discovered models whose id starts with one of the listed
#   prefixes are included. Leave blank to include all.
#   Example: global/,ibm/
DYNAMIC_MODEL_LISTING_PREFIX_FILTER=

# =============================================================================
# Active / Fallback Model Selection
# =============================================================================
# AI_MODEL      : The model used for all requests unless overridden per-role in
#                 models.yaml or per-request via the API/UI.
AI_MODEL=global/anthropic.claude-sonnet-4-6

# AVAILABLE_MODELS
#   Comma-separated ordered list of model ids to use as a fallback chain when
#   AI_MODEL fails or is unavailable (e.g. rate-limited, not returned by the
#   live catalogue). The first model in the list that is available wins.
#   Leave blank to disable fallback -- a failed model will surface as an error.
#
#   Tip: mirror the order of quality/cost preference you want, best first.
AVAILABLE_MODELS=global/anthropic.claude-sonnet-4-6,global/gpt-5.1-chat,global/meta-llama/llama-3-3-70b-instruct,global/mistralai/mistral-medium-2505,global/ibm/granite-4-h-small

# ===== TESTED WORKING MODELS (uncomment ONE to override AI_MODEL) =====
# AI_MODEL=global/anthropic.claude-sonnet-4-5-20250929-v1:0
# AI_MODEL=global/claude-3-7-sonnet-1
# AI_MODEL=global/gpt-5.1-chat
# AI_MODEL=global/ibm/granite-4-h-small
# AI_MODEL=global/meta-llama/llama-3-3-70b-instruct
# AI_MODEL=global/mistralai/mistral-medium-2505
# AI_MODEL=global/o3-mini

# =============================================================================
# Model Inference Parameters
# =============================================================================
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=64000

# =============================================================================
# Misc Application Settings
# =============================================================================
TRANSFORMERS_OFFLINE=1
WEAVIATE_PORT=8090
AUTH_TOKEN=

# =============================================================================
# mem0 auto-learning memory (library mode, backed by the same Weaviate)
# =============================================================================
# Weaviate collection that mem0 stores extracted facts in.
# MEM0_COLLECTION=Mem0Conversations
# Model mem0 uses to extract facts from conversations. Defaults to AI_MODEL.
# Override if AI_MODEL doesn't handle structured extraction well.
# MEM0_LLM_MODEL=global/anthropic.claude-sonnet-4-6
# Extended-thinking models on the ICA gateway require
# max_tokens > thinking.budget_tokens; keep this comfortably high.
# MEM0_MAX_TOKENS=4096
#
# AUTO_MEMORY_MAX_TOKENS — max_tokens for auto-memory fact-extraction calls.
# Same extended-thinking constraint applies. Default: 4096.
# AUTO_MEMORY_MAX_TOKENS=4096

# =============================================================================
# Telemetry (OpenTelemetry) - Step 7: KRS otel-collector
# =============================================================================
#
# BEFORE: Beacon's own collector  ->  http://localhost:14318  (HTTP/protobuf)
#   docker-compose.telemetry.yml host port 14318 mapped to container 4318
#
# AFTER:  KRS otel-collector      ->  http://localhost:4317   (gRPC)
#   krs-service/docker/otel-config.yaml:
#     receivers.otlp.protocols.grpc.endpoint: 0.0.0.0:4317
#   krs-service/docker-compose.yaml:
#     ports: "4317:4317"
#
# Beacon tracer.py uses proto.grpc exporters (no /v1/traces suffix needed).
# service.name=beacon lets KRS Loki label Beacon logs distinctly.
#
# Start KRS stack before running Beacon:
#   cd /path/to/krs-service
#   docker compose up -d loki tempo prometheus grafana otel-collector
#   nc -z localhost 4317 && echo "gRPC ready"
#
# DO NOT start docker-compose.telemetry.yml (Beacon's own stack, replaced by KRS).
# =============================================================================
OTEL_SERVICE_NAME=beacon
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
OTEL_RESOURCE_ATTRIBUTES=service.name=beacon,service.version=0.1.0,deployment.environment=development,job=beacon
OTEL_ENABLED=true
