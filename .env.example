# AI Assistant Configuration - IBM ICA
# Copy this file to .env and fill in your actual credentials
# DO NOT commit .env to version control!

# IBM ICA API Key
OPENAI_API_KEY=your_ibm_ica_api_key_here

# IBM ICA API Endpoint
OPENAI_BASE_URL=https://sg.ica.ibm.com/ica/apis/v3

# IBM ICA Claude Sonnet Model (ACTIVE)
AI_MODEL=global/anthropic.claude-sonnet-4-6

# ===== TESTED WORKING MODELS =====
# AI_MODEL=global/anthropic.claude-sonnet-4-5-20250929-v1:0
# AI_MODEL=global/claude-3-7-sonnet-1
# AI_MODEL=global/gpt-5.1-chat
# AI_MODEL=global/ibm/granite-4-h-small
# AI_MODEL=global/meta-llama/llama-3-3-70b-instruct
# AI_MODEL=global/mistralai/mistral-medium-2505
# AI_MODEL=global/o3-mini

AI_TEMPERATURE=0.7
AI_MAX_TOKENS=64000
TRANSFORMERS_OFFLINE=1
WEAVIATE_PORT=8090
AUTH_TOKEN=

# =============================================================================
# Telemetry (OpenTelemetry) - Step 7: KRS otel-collector
# =============================================================================
#
# BEFORE: Beacon's own collector  ->  http://localhost:14318  (HTTP/protobuf)
#   docker-compose.telemetry.yml host port 14318 mapped to container 4318
#
# AFTER:  KRS otel-collector      ->  http://localhost:4317   (gRPC)
#   krs-service/docker/otel-config.yaml:
#     receivers.otlp.protocols.grpc.endpoint: 0.0.0.0:4317
#   krs-service/docker-compose.yaml:
#     ports: "4317:4317"
#
# Beacon tracer.py uses proto.grpc exporters (no /v1/traces suffix needed).
# service.name=beacon lets KRS Loki label Beacon logs distinctly.
#
# Start KRS stack before running Beacon:
#   cd /path/to/krs-service
#   docker compose up -d loki tempo prometheus grafana otel-collector
#   nc -z localhost 4317 && echo "gRPC ready"
#
# DO NOT start docker-compose.telemetry.yml (Beacon's own stack, replaced by KRS).
# =============================================================================
OTEL_SERVICE_NAME=beacon
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
OTEL_RESOURCE_ATTRIBUTES=service.name=beacon,service.version=0.1.0,deployment.environment=development,job=beacon
OTEL_ENABLED=true
