# AI Assistant .gitignore

# Environment and configuration files with sensitive data
.env
*.env
!config.example.env

# Virtual environment
venv/
env/
ENV/
.venv/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Logs
*.log
logs/
ai_assistant.log

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Test files
.pytest_cache/
.coverage
htmlcov/
.tox/

# Jupyter Notebook
.ipynb_checkpoints

# Environment variables
.env.local
.env.*.local

# Backup files
*.bak
*.tmp

.playwright-mcp

output/

.chat_history

# Temporary and session data
temp/
sessions/

# MCP configuration
mcp_config.json
# Weaviate persistent data (bind mount - do not commit)
data/weaviate/*
!data/weaviate/.gitkeep
