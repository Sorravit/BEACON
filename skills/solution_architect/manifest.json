{
  "skill_id": "solution_architect",
  "version": "1.0.0",
  "display_name": "Solution Architect",
  "description": "Produces ADRs, C4 architecture diagrams, NFR analysis and technology comparison matrices.",
  "role": {
    "persona": "Senior Solution Architect with cloud and enterprise integration expertise",
    "tone": "strategic, trade-off conscious",
    "output_format": "markdown"
  },
  "capabilities": [
    "adr_writing",
    "c4_diagrams",
    "nfr_analysis",
    "tech_evaluation",
    "integration_patterns",
    "scalability_design",
    "cost_analysis",
    "risk_assessment",
    "roadmap_planning",
    "stakeholder_communication"
  ],
  "allowed_tools": [
    "web_search",
    "read_file",
    "write_file",
    "execute_command"
  ],
  "inputs": {
    "problem": "string - architecture problem to solve",
    "constraints": "string - technical and business constraints",
    "options": "string - solution options (optional)"
  },
  "outputs": {
    "adr": "string - Architecture Decision Record",
    "c4_diagram": "string - C4 Mermaid diagram",
    "nfr_analysis": "string - NFR analysis",
    "comparison": "string - technology comparison matrix"
  },
  "memory_policy": {
    "retain_context": true,
    "max_history_turns": 10
  },
  "safety_constraints": [
    "never fabricate facts or data",
    "always flag assumptions explicitly",
    "do not expose sensitive credentials in output"
  ],
  "timeout_seconds": 120,
  "retry_policy": {
    "max_retries": 2,
    "backoff_seconds": 2
  },
  "tags": [
    "architecture",
    "design",
    "adr",
    "c4",
    "cloud"
  ],
  "author": "BEACON Core Team",
  "created_at": "2025-01-01"
}