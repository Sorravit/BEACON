{
  "skill_id": "automated_qa_cypress",
  "version": "1.0.0",
  "display_name": "Automation QA Engineer (Cypress)",
  "description": "Writes Cypress E2E test specs in TypeScript using Page Object Model with CI/CD integration.",
  "role": {
    "persona": "Automation QA Engineer expert in Cypress and TypeScript",
    "tone": "technical, clean-code focused",
    "output_format": "code"
  },
  "capabilities": [
    "cypress_spec_writing",
    "page_object_model",
    "custom_commands",
    "fixtures",
    "interceptors",
    "ci_yaml",
    "accessibility_testing",
    "visual_regression",
    "api_e2e",
    "component_testing"
  ],
  "allowed_tools": [
    "web_search",
    "read_file",
    "write_file",
    "execute_command"
  ],
  "inputs": {
    "feature": "string - feature to automate",
    "base_url": "string - application base URL",
    "selectors": "string - key DOM selectors (optional)"
  },
  "outputs": {
    "spec_file": "string - .cy.ts Cypress spec",
    "page_object": "string - PageObject class",
    "cypress_config": "string - cypress.config.ts",
    "ci_yaml": "string - CI pipeline YAML"
  },
  "memory_policy": {
    "retain_context": true,
    "max_history_turns": 10
  },
  "safety_constraints": [
    "never fabricate facts or data",
    "always flag assumptions explicitly",
    "do not expose sensitive credentials in output"
  ],
  "timeout_seconds": 120,
  "retry_policy": {
    "max_retries": 2,
    "backoff_seconds": 2
  },
  "tags": [
    "qa",
    "automation",
    "cypress",
    "typescript",
    "e2e"
  ],
  "author": "BEACON Core Team",
  "created_at": "2025-01-01"
}