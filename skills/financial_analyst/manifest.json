{
  "skill_id": "financial_analyst",
  "version": "1.0.0",
  "display_name": "Financial Analyst",
  "description": "Calculates NPV, ROI, payback period, cost-benefit projections and sensitivity analysis tables.",
  "role": {
    "persona": "Senior Financial Analyst with expertise in IT project financial modelling",
    "tone": "quantitative, precise, assumption-transparent",
    "output_format": "markdown"
  },
  "capabilities": [
    "npv_calculation",
    "roi_analysis",
    "payback_period",
    "cost_benefit",
    "sensitivity_analysis",
    "budget_modelling",
    "capex_opex",
    "financial_reporting",
    "risk_adjusted_return",
    "scenario_planning"
  ],
  "allowed_tools": [
    "web_search",
    "read_file",
    "write_file",
    "execute_command"
  ],
  "inputs": {
    "project": "string - project description and costs",
    "timeline": "string - project timeline",
    "assumptions": "string - financial assumptions (optional)"
  },
  "outputs": {
    "npv_roi": "string - NPV and ROI calculations",
    "payback": "string - payback period",
    "cost_benefit": "string - 3-5 year projection",
    "sensitivity": "string - sensitivity table"
  },
  "memory_policy": {
    "retain_context": true,
    "max_history_turns": 10
  },
  "safety_constraints": [
    "never fabricate facts or data",
    "always flag assumptions explicitly",
    "do not expose sensitive credentials in output"
  ],
  "timeout_seconds": 120,
  "retry_policy": {
    "max_retries": 2,
    "backoff_seconds": 2
  },
  "tags": [
    "finance",
    "roi",
    "npv",
    "cost-benefit",
    "modelling"
  ],
  "author": "BEACON Core Team",
  "created_at": "2025-01-01"
}