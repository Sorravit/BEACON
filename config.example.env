# AI Assistant Configuration Example
# Copy this file to .env and fill in your actual values

# Required: Your OpenAI API key or compatible API key
# For IBM ICA: Use the format provided by your service
OPENAI_API_KEY=your-api-key-here

# Optional: Custom API endpoint URL
# Default: https://api.openai.com/v1
# For IBM ICA: https://sg.ica.ibm.com/ica/apis/v3
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: Model name to use
# Default: gpt-3.5-turbo
# For IBM ICA Claude Sonnet: global/anthropic.claude-sonnet-4-5-20250929-v1:0
AI_MODEL=gpt-3.5-turbo

# Optional: Path to the curated model registry (selectable models + role defaults)
# Default: models.yaml (in the project root)
MODELS_CONFIG_FILE=models.yaml

# Optional: Directory containing Agent Skills (each subfolder has a SKILL.md)
# Default: skills
SKILLS_DIR=skills

# Optional: Temperature for response generation (0.0 to 2.0)
# Default: 0.7
# Lower values = more focused and deterministic
# Higher values = more creative and random
AI_TEMPERATURE=0.7

# Optional: Maximum tokens in the response
# Default: 1000
AI_MAX_TOKENS=1000

# Optional: Slack Incoming Webhook URL for the slack_notify tool
# Used by the agent to send messages to a Slack channel
# Get yours from: https://api.slack.com/messaging/webhooks
# Example: your-slack-webhook-url-here
SLACK_WEBHOOK_URL=your-slack-webhook-url-here

# Optional: Weaviate vector DB port (default: 8090)
# Change this if port 8090 conflicts with another application
# Must match the WEAVIATE_PORT used when starting Docker: docker compose up -d
WEAVIATE_PORT=8090

# Optional: Set to 1 after first run to skip HuggingFace network checks
# The all-MiniLM-L6-v2 embedding model is cached locally after first download
# Setting this to 1 prevents ~20 HTTP requests to huggingface.co on every startup
TRANSFORMERS_OFFLINE=1